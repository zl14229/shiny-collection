# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30
SERVER_WRITE_TIMEOUT=30

# Database
DB_PATH=./data/shiny.db

# JWT
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRE_HOUR=720

# Log
LOG_LEVEL=info
LOG_OUTPUT=./logs/app.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=28

# CORS - frontend dev server
CORS_ORIGIN=http://localhost:5173
